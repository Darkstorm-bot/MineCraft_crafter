        "properties": {
          "issue_code": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2", "P3"]},
          "message": {"type": "string"},
          "module_name": {"type": "string"},
          "suggested_fix": {"type": "string"}
        }
      }
    },
    "approval_flag": {"type": "boolean"}
  }
}
