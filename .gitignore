```gitignore
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.py~

# Dependencies
venv/
.venv/
.env
.env.local
*.env.*

# Database
*.db

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
htmlcov/
coverage/

# IDE specific
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Build artifacts
build/
dist/
*.egg-info/
target/
out/

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```